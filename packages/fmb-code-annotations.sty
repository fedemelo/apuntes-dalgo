\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{fmb-code-annotations}[2026/05/10 Code annotation infrastructure by Federico Melo Barrero.]

\RequirePackage{tikz}
\usetikzlibrary{arrows.meta,calc,positioning,fit,decorations.pathreplacing}

% Place a zero-size remembered node at the current position.
\newcommand{\tikzmark}[1]{\tikz[remember picture,overlay] \node (#1) {};}

% Shorthand for brace marks: |\br{id}|
\newcommand{\br}[1]{\tikzmark{#1}}

% Shorthand pair for box marks: |\bxl{id}|TOKEN|\bxr{id}|
\newcommand{\bxl}[1]{\tikzmark{#1s}}
\newcommand{\bxr}[1]{\tikzmark{#1e}}

\tikzset{
  box/.style={draw=green!55!black, line width=0.7pt,
              rounded corners=3pt, inner xsep=0pt, inner ysep=2pt, yshift=2pt},
  note/.style={align=left, font=\scriptsize\fontfamily{cmss}\selectfont,
               text=green!50!black, inner sep=5pt},
  arr/.style={-{Stealth[length=2mm,open]}, draw=green!55!black, line width=0.7pt},
  brk/.style={draw=green!55!black, line width=0.7pt},
}



% Curly brace spanning a vertical range of code, with an inline label

% -------------------------------------------------
%
%   \codebrace[<options>]{<top>}{<bottom>}{<text>}
%
% -------------------------------------------------
% Mandatory arguments
% -------------------------------------------------
%
%   {<top>}
%       TikZ coordinate/node marking the TOP of the
%       brace span.
%
%   {<bottom>}
%       TikZ coordinate/node marking the BOTTOM of
%       the brace span.
%
%   {<text>}
%       Text displayed next to the brace.
%
% -------------------------------------------------
% Optional key-value options
% -------------------------------------------------
%
%   xshift=<dimension>
%       Horizontal displacement of the brace from
%       the bottom mark.
%
%       Positive values move the brace right.
%       Negative values move it left.
%
%       Default:
%           15pt
%
%   noteshift=<dimension>
%       Horizontal distance between the brace tip
%       and the annotation text.
%
%       Default:
%           0pt
%
%   yshift=<dimension>
%       Vertical displacement of the annotation text
%       relative to the brace midpoint.
%
%       Positive values move the text up.
%       Negative values move it down.
%
%       Default:
%           0pt
%
%   width=<dimension>
%       Text width of the annotation node.
%
%       Useful for wrapping long explanations.
%
%       Default:
%           3cm
%
%   amplitude=<dimension>
%       Curvature size of the curly brace.
%
%       Larger values produce "deeper" braces.
%
%       Default:
%           3pt

\pgfkeys{
    /codebrace/.is family,
    /codebrace,
    default/.style = {
        xshift = 15pt,
        noteshift = 0pt,
        yshift = 0pt,
        width = 3cm,
        amplitude = 3pt
    },
    xshift/.estore in = \codebracexshift,
    noteshift/.estore in = \codebracenoteshift,
    yshift/.estore in = \codebraceyshift,
    width/.estore in = \codebracewidth,
    amplitude/.estore in = \codebraceamplitude,
}

\NewDocumentCommand{\codebrace}{O{} m m m}{%
    \pgfkeys{/codebrace, default, #1}
    \coordinate (brace@x)
        at ([xshift=\codebracexshift] #3);
    \draw[
        brk,
        decorate,
        decoration = {
            brace,
            amplitude=\codebraceamplitude
        }
    ]
        ($ (brace@x |- #2) + (0, \dimexpr\ht\strutbox - 3pt\relax) $)
        --
        (brace@x |- #3)
        node[
            midway,
            note,
            anchor=west,
            xshift=\the\dimexpr\codebraceamplitude+\codebracenoteshift\relax,
            yshift=\codebraceyshift,
            text width=\codebracewidth
        ]
        {#4};
}

% Box around a code token, a floating note, and an arrow connecting them.
%
% -------------------------------------------------
%
%   \codebox[<options>]{<id>}{<text>}
%
% -------------------------------------------------
% Marks in the listing
% -------------------------------------------------
%
%   Place |\bxl{id}| before the token and |\bxr{id}| after it.
%
% Mandatory arguments
% -------------------------------------------------
%
%   {<id>}
%       Base name matching the \bxl{id}/\bxr{id} marks.
%
%   {<text>}
%       Explanation text in the note.
%
% -------------------------------------------------
% Optional key-value options
% -------------------------------------------------
%
%   xshift=<dimension>
%       Horizontal distance from the box to the note.
%       Controls the arrow length in the default layout.
%       Ignored when notepos is set explicitly.
%
%       Default:
%           1.5cm
%
%   notepos=<calc expression>
%       Where to place the note, written as a TikZ
%       calc expression without the outer ($ ... $).
%       E.g.: (cbox@id.east)+(2cm,1cm)
%             (current page.east)+(-8.5cm,-0.5cm)
%       Overrides xshift when set.
%
%       Default:
%           auto (xshift to the right of the box)
%
%   noteanchor=<anchor>
%       Anchor of the note node used for positioning.
%
%       Default:
%           west
%
%   from=<anchor>
%       Box anchor where the arrow starts.
%
%       Default:
%           east
%
%   to=<anchor>
%       Note anchor where the arrow ends.
%
%       Default:
%           west
%
%   curve=<to-path options>
%       TikZ to-path options controlling the arrow shape.
%       E.g.: bend left=25, out=90 in=180
%
%       Default:
%           {} (straight line)
%
%   arrstyle=<draw options>
%       Extra options passed to \draw for the arrow.
%       E.g.: solid, dashed
%
%       Default:
%           dotted
%
%   width=<dimension>
%       Text width of the note node.
%
%       Default:
%           3cm

\pgfkeys{
    /codebox/.is family,
    /codebox,
    default/.style = {
        notepos    = auto,
        noteanchor = west,
        xshift     = 1.5cm,
        from       = east,
        to         = west,
        curve      = {},
        arrstyle   = dotted,
        width      = 3cm,
    },
    notepos/.store     in = \codeboxnotepos,
    noteanchor/.estore in = \codeboxnoteanchor,
    xshift/.estore     in = \codeboxnotexshift,
    from/.estore       in = \codeboxfrom,
    to/.estore         in = \codeboxto,
    curve/.code           = {\tikzset{codebox@curve@style/.style={#1}}},
    arrstyle/.estore   in = \codeboxarrstyle,
    width/.estore      in = \codeboxwidth,
}

\NewDocumentCommand{\codebox}{O{} m m}{%
    \pgfkeys{/codebox, default, #1}%
    \node[box, fit=(#2s)(#2e)] (cbox@#2) {};%
    \def\codebox@auto{auto}%
    \ifx\codeboxnotepos\codebox@auto
        \node[note, anchor=\codeboxnoteanchor, text width=\codeboxwidth]
            (cnote@#2) at ([xshift=\codeboxnotexshift] cbox@#2.east) {#3};%
    \else
        \edef\codebox@pos{($ \codeboxnotepos $)}%
        \node[note, anchor=\codeboxnoteanchor, text width=\codeboxwidth]
            (cnote@#2) at \codebox@pos {#3};%
    \fi
    \draw[arr, \codeboxarrstyle]
        (cbox@#2.\codeboxfrom) to[codebox@curve@style] (cnote@#2.\codeboxto);%
}

\NewDocumentEnvironment{annotations}{}{%
    \begin{tikzpicture}[remember picture, overlay]
}{%
    \end{tikzpicture}
}
